SOVA_INTEL_BASE_URL=http://localhost:3001/api/v1
SOVA_INTEL_API_KEY=

X_API_BASE_URL=https://api.x.com/2
X_BOT_USERNAME=sova_intel
X_BOT_USER_ID=
X_BEARER_TOKEN=

# OAuth 1.0a user-context credentials for media upload and post creation.
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# OAuth 2.0 PKCE / user-context write path
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH2_REDIRECT_URI=http://127.0.0.1:8765/callback
X_OAUTH2_ACCESS_TOKEN=
X_OAUTH2_REFRESH_TOKEN=

# CSV of allowed caller user IDs.
X_ALLOWED_CALLER_IDS=

# Local test controls.
SOVA_X_POLL_INTERVAL_MS=5000
SOVA_X_TOP_N=20
SOVA_X_OUTPUT_DIR=./out

# Manual trigger route deployment.
SOVA_X_MANUAL_HOST=0.0.0.0
SOVA_X_MANUAL_PORT=8787
SOVA_X_MANUAL_BASE_PATH=/manual-trigger

# CSV allowlists for dashboard-authenticated internal users forwarded to sova-x
# via x-sova-user-id / x-sova-user-email headers.
SOVA_X_MANUAL_ALLOWED_USER_IDS=
SOVA_X_MANUAL_ALLOWED_USER_EMAILS=
